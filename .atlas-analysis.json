  "keyFeatures": [
    "Complete LLM training pipeline from tokenization to chat UI",
    "Compute-optimal model training with automatic hyperparameter scaling",
    "GPT-2 capability training for under $100 on 8xH100",
    "FP8 training support for Hopper+ GPUs",
    "Flash Attention 3 integration",
    "Distributed training with torchrun",
    "DCLM CORE metric evaluation",
    "Multiple evaluation tasks (ARC, MMLU, GSM8K, HumanEval)",
    "ChatGPT-like web UI and CLI chat interfaces",
    "BPE tokenizer training",
    "Supervised fine-tuning (SFT) and reinforcement learning (RL)",
    "Minimal, hackable codebase designed for research"
  ],
  "publicApiSurface": [
    "GPT - Transformer model with rotary embeddings, QK norm, and GQA",
    "GPTConfig - Model configuration dataclass",
    "Engine - Efficient inference with KV cache",
    "get_tokenizer - BPE tokenizer wrapper",
    "MuonAdamW - Muon optimizer for matrix parameters",
    "DistMuonAdamW - Distributed Muon optimizer",
    "save_checkpoint - Save model checkpoints",
    "load_checkpoint - Load model checkpoints",
    "evaluate_bpb - Evaluate bits per byte",
    "evaluate_core - Evaluate DCLM CORE metric",
    "tokenizing_distributed_data_loader_bos_bestfit - Distributed data loader",
    "scripts.base_train - Pretrain base model",
    "scripts.base_eval - Evaluate base model",
